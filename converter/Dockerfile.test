FROM python:3.11-slim
WORKDIR /app

COPY requirements.txt requirements-test.txt ./
RUN pip install --no-cache-dir -r requirements.txt -r requirements-test.txt

COPY md2html.py tex_extract.py ./
COPY tests/ ./tests/

CMD ["pytest", "tests/", "--cov=md2html", "--cov-report=term-missing", \
     "--cov-report=html:/reports/converter", "-v"]
