# Copy this file to .env and edit as needed.
# .env is in .gitignore — never commit real credentials.

# ── Projector page password ─────────────────────────────────────────────────
# Shown on the login form before the presenter can access the slides.
# Set to empty string ("") to disable password protection entirely.
PROJECTOR_PASSWORD=changeme

# ── Optional WebSocket projector auth token ──────────────────────────────────
# When set, the presenter's browser must send this token when registering
# as the projector over WebSocket. Leave empty to skip this check.
PROJECTOR_SECRET=

# ── Network / host ───────────────────────────────────────────────────────────
# Hostname or IP baked into the QR code and slide WebSocket URL.
# deploy.sh auto-detects your LAN IP; override only if needed.
SERVER_HOST=localhost

# Port the server listens on (and that deploy.sh exposes in URLs).
PORT=8000

# WebSocket scheme: "ws" for plain HTTP, "wss" for HTTPS/TLS deployments.
# deploy.sh sets this automatically for --https and VPS modes.
WS_SCHEME=ws
